{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Port Manager",
  "version": "0.1.3",
  "identifier": "com.internal-tools.port-manager",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:9090",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Port Manager",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "publisher": "Meliorate",
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDREMDQ4NjI5RDBGRDY5MDUKUldRRmFmM1FLWVlFVFdoSWt3UzgwQnZFeVNmTjgxY3RLS2tEbmx4Kzdsa3N2VTRzaXoxa210cUgK",
      "endpoints": [
        "https://github.com/Meliorate-agency/port-manager/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
